{
  "author": "Octopus Deploy",
  "bugs": {
    "url": "https://github.com/OctopusDeploy/install-octopus-cli-action/issues"
  },
  "dependencies": {
    "@actions/core": "3.0.0",
    "@actions/http-client": "4.0.0",
    "@actions/tool-cache": "4.0.0",
    "uuid": "9.0.1"
  },
  "description": "GitHub Action to Install the Octopus CLI",
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/jest": "29.5.14",
    "@types/node": "24.7.2",
    "@types/semver": "7.7.1",
    "@types/tmp": "0.2.6",
    "@types/uuid": "9.0.8",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "cross-env": "^10.1.0",
    "esbuild": "0.25.1",
    "eslint": "9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-github": "6.0.0",
    "eslint-plugin-jest": "29.15.1",
    "globals": "16.5.0",
    "jest": "29.7.0",
    "jest-circus": "29.7.0",
    "jest-junit": "15.0.0",
    "js-yaml": "4.1.1",
    "prettier": "2.8.8",
    "tmp": "0.2.5",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3"
  },
  "homepage": "https://github.com/OctopusDeploy/install-octopus-cli-action#readme",
  "main": "dist/index.js",
  "name": "install-octopus-cli-action",
  "jest": {
    "clearMocks": true,
    "collectCoverage": true,
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "setupFiles": [
      "<rootDir>/src/test-setup.ts"
    ],
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "testRunner": "jest-circus/runner",
    "testTimeout": 10000,
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "verbose": true
  },
  "jest-junit": {
    "outputDirectory": "reports",
    "outputName": "jest-junit.xml",
    "ancestorSeperator": " > ",
    "uniqueOutputName": "false",
    "suiteNameTemplate": "{filepath}",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}"
  },
  "keywords": [
    "cli",
    "deployment",
    "octopus-deploy",
    "github-actions"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OctopusDeploy/install-octopus-cli-action.git"
  },
  "scripts": {
    "all": "npm run format && npm run build && npm test",
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --outfile=dist/index.js",
    "prebuild": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --ci --reporters=default --reporters=jest-junit --passWithNoTests"
  },
  "version": "4.1.0"
}
